# ================================================================
# OPC UA Platform — Environment Configuration
# Copy this to .env and configure for your site.
# ================================================================

# ── PostgreSQL / TimescaleDB ─────────────────────────────────────
POSTGRES_DB=opcua
POSTGRES_USER=opcua_admin
POSTGRES_PASSWORD=changeme_strong_pass

# ── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=redis_pass

# -DigitalTwin
FEATURE_DIGITAL_TWIN=true
FEATURE_TWIN_PREDICTIVE=true

# ── OPC UA Server connection ─────────────────────────────────────
OPC_SERVER_URL=opc.tcp://192.168.1.100:4840
OPC_SERVER_NAME=My PLC Server
# Security: None | Sign | SignAndEncrypt
OPC_SECURITY_MODE=None
# Policy: None | Basic256Sha256 | Aes128Sha256RsaOaep
OPC_SECURITY_POLICY=None
OPC_USERNAME=
OPC_PASSWORD=
# For SignAndEncrypt (paths inside container):
OPC_CERTIFICATE_PATH=/app/certs/client_cert.pem
OPC_PRIVATE_KEY_PATH=/app/certs/client_key.pem

# ── Client tuning ────────────────────────────────────────────────
PUBLISH_INTERVAL_MS=1000
BUFFER_FLUSH_INTERVAL_S=5
BATCH_INSERT_SIZE=500

# ================================================================
# FEATURE FLAGS — set true/false to enable/disable modules
# No code changes required. Restart services after changing.
# ================================================================

# Read & subscribe to OPC UA nodes → time series DB (always on)
# (no flag needed — core functionality)

# Write values to OPC UA nodes (priority queue, audit trail, read-back)
FEATURE_WRITE=true

# Call OPC UA Method nodes (templates, emergency stop, audit)
FEATURE_METHODS=true

# Connect to multiple OPC UA servers simultaneously
FEATURE_MULTI_SERVER=false

# Real-time alarm evaluation engine (threshold checks on live data)
FEATURE_ALARM_EVAL=true

# Scheduled reads, writes, and set-point ramps
FEATURE_SCHEDULER=false

# Kafka high-throughput ingestion pipeline
# When false: OPC UA → TimescaleDB directly (good up to ~10k rows/sec)
# When true:  OPC UA → Kafka → N consumers → TimescaleDB (1M+ rows/sec)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
KAFKA_TOPIC=opcua.tag.values

# Edge-to-cloud sync (sync local historian to cloud TimescaleDB)
FEATURE_EDGE_SYNC=false
EDGE_CLOUD_DSN=

# ── API ──────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_hex
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Frontend ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_grafana_password

# ── Alerts ───────────────────────────────────────────────────────
ALERT_EMAIL=admin@opcua.local

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
